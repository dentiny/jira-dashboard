# ── Required ────────────────────────────────────────────────
JIRA_CODER_BIN=opencode                  # Path to your AI coder CLI binary

# ── Server ─────────────────────────────────────────────────
# PORT=3006

# ── Project ────────────────────────────────────────────────
# JIRA_PROJECT_NAME=my-project           # Display name in header
# JIRA_WORKTREES_DIR=                    # Where git worktrees live

# ── Coder ──────────────────────────────────────────────────
# JIRA_CODER_TYPE=opencode               # Backend name in coder.js

# ── Python (only for Python projects) ──────────────────────
# JIRA_VENV_DIR=.venv
# JIRA_PYTHONPATH=src

# ── Testing (opt-in, default off) ──────────────────────────
# JIRA_TEST_ENABLED=true
# JIRA_TEST_CMD=
# JIRA_TEST_TIMEOUT=300000

# ── Remote editor links ────────────────────────────────────
# REMOTE_HOST=example-claw

# ── File explorer ──────────────────────────────────────────
# EXPLORER_URL=https://github.com/{owner}/{repo}/blob/{sha}/{path}
# GITHUB_OWNER=
# GITHUB_REPO=

# ── Close/merge ────────────────────────────────────────────
# MERGE_STRATEGY=cherry-pick

# ── Git ────────────────────────────────────────────────────
# GIT_DEFAULT_BRANCH=                # Auto-detected from remote 'origin' at install time

# ── Database ───────────────────────────────────────────────
# JIRA_DATA_DIR=
# DB_BUSY_TIMEOUT=5000
